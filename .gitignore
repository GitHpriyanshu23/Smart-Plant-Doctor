ai/data/processed/

# Ignore AI image assets in ai/ directory tree
ai/**/*.jpg
ai/**/*.jpeg
ai/**/*.png
ai/**/*.webp
ai/**/*.gif

# Keep only exported model artifacts in ai/exports
!ai/exports/
!ai/exports/smart_plant_doctor_model.pth
!ai/exports/class_mapping.json

